# TrendScope / SentinelAI 本地配置示例
# 复制为 `.env` 后填写真实密钥；不要把 `.env` 提交到仓库。
# 填写格式必须是 KEY=value，不要单独写一行 value。

# ====================== 服务配置 ======================
# 后端监听地址。
HOST=0.0.0.0
# 后端端口。
PORT=5000
# 前端开发/容器端口。
FRONTEND_PORT=5173
# Docker 暴露数据库端口。
DB_EXPOSE_PORT=3307
# 日志等级：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL=INFO

# ====================== 数据库配置 ======================
# Insight Agent / SentinelSpider 使用的本地舆情数据库。
DB_DIALECT=mysql
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=media_crawler
DB_CHARSET=utf8mb4
# 可选：若提供完整连接串，会优先供部分数据库工具使用。
DATABASE_URL=

# ====================== LLM Agent 密钥配置 ======================
# Insight Agent：本地舆情库分析、风险分析、深度洞察。
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=https://api.moonshot.cn/v1
INSIGHT_ENGINE_MODEL_NAME=kimi-k2-0711-preview

# Media Agent：视频平台热点、传播趋势、评论情绪和内容爆点分析。
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=https://aihubmix.com/v1
MEDIA_ENGINE_MODEL_NAME=gemini-2.5-pro

# Query Agent：公开搜索事实核查、可信来源聚合、事件时间线辅助。
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=https://api.deepseek.com
QUERY_ENGINE_MODEL_NAME=deepseek-chat

# Report Agent：长报告生成、报告结构整理、图表/表格修复。
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=https://aihubmix.com/v1
REPORT_ENGINE_MODEL_NAME=gemini-2.5-pro

# Forum Host：多个 Agent 讨论后的主持人总结，可选。
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SentinelSpider Agent：本地采集工具的 LLM 辅助能力，可选。
SENTINEL_SPIDER_API_KEY=
SENTINEL_SPIDER_BASE_URL=
SENTINEL_SPIDER_MODEL_NAME=

# Keyword Optimizer：Insight Agent 查询改写/关键词优化。
# 不配置也能运行，系统会回退为原始查询；配置后改写更贴近舆情库检索。
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# ====================== 公开搜索密钥配置 ======================
# TrendScope / Query Agent / Media Agent 使用公开搜索，不做登录爬虫和绕过风控。
# 可选值：TavilyAPI / AnspireAPI / BochaAPI。
SEARCH_TOOL_TYPE=TavilyAPI
# Tavily 搜索。
TAVILY_API_KEY=
# Anspire 搜索。
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=
# Bocha 搜索。
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=
BOCHA_API_KEY=

# ====================== Insight 本地模型配置 ======================
# SENTIMENT_MODEL_NAME：情感分析模型名或本地路径；首次使用公开模型名可能下载 HuggingFace 模型。
SENTIMENT_MODEL_NAME=tabularisai/multilingual-sentiment-analysis
# SENTIMENT_ANALYSIS_ENABLED：是否启用情感分析总开关。
SENTIMENT_ANALYSIS_ENABLED=True
# ENABLE_SENTIMENT_PER_SEARCH：每次搜索是否默认执行情感分析。
ENABLE_SENTIMENT_PER_SEARCH=True
# CLUSTERING_MODEL_NAME：搜索结果聚类的 sentence-transformers 模型名或本地路径。
CLUSTERING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
# ENABLE_CLUSTERING：是否启用搜索结果聚类。
ENABLE_CLUSTERING=True
MAX_CLUSTERED_RESULTS=50
RESULTS_PER_CLUSTER=5

# ====================== 搜索与报告运行参数 ======================
DEFAULT_SEARCH_HOT_CONTENT_LIMIT=100
DEFAULT_SEARCH_TOPIC_GLOBALLY_LIMIT_PER_TABLE=50
DEFAULT_SEARCH_TOPIC_BY_DATE_LIMIT_PER_TABLE=100
DEFAULT_GET_COMMENTS_FOR_TOPIC_LIMIT=500
DEFAULT_SEARCH_TOPIC_ON_PLATFORM_LIMIT=200
MAX_SEARCH_RESULTS_FOR_LLM=0
MAX_HIGH_CONFIDENCE_SENTIMENT_RESULTS=0
MAX_REFLECTIONS=3
MAX_PARAGRAPHS=6
SEARCH_TIMEOUT=240
MAX_CONTENT_LENGTH=500000
SEARCH_CONTENT_MAX_LENGTH=500000
SAVE_INTERMEDIATE_STATES=True
MAX_SEARCH_RESULTS=20

# ====================== LLM 请求超时，可选 ======================
LLM_REQUEST_TIMEOUT=1800
INSIGHTENGINE_REQUEST_TIMEOUT=1800
MEDIAENGINE_REQUEST_TIMEOUT=1800
QUERYENGINE_REQUEST_TIMEOUT=1800
REPORTENGINE_REQUEST_TIMEOUT=1800
